# Hugging Face token if you need to access gated models
# HF_TOKEN=hf_xxx

# Base model and LoRA adapter
BASE_MODEL_ID=unsloth/DeepSeek-R1-Distill-Qwen-7B-bnb-4bit
LORA_REPO_ID=Thrgbbnh/cucpo_lora

# Optional: local adapter path inside container (not needed if using LORA_REPO_ID)
# LORA_PATH=/app/cucpo_lora

# Gradio will listen on PORT
PORT=7860
