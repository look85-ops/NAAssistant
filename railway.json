{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "nixpacksPlan": {
      "phases": {
        "setup": {"nixPkgs": ["python311", "pip"]},
        "install": {"cmds": ["pip install -r bot_mvp/requirements.txt", "pip install gunicorn"]},
        "start": {"cmd": "gunicorn -w 2 -k gthread -b 0.0.0.0:$PORT bot_mvp.app:app"}
      }
    }
  },
  "deploy": {
    "healthcheckPath": "/health",
    "healthcheckTimeout": 10000
  }
}
